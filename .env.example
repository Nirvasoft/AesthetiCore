# =============================================================================
# AesthetiCore — Environment Variables
# Copy this file to .env and fill in values
# =============================================================================

# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://aestheticore:aestheticore_dev@localhost:5432/aestheticore?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Keycloak (Auth)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aestheticore
KEYCLOAK_CLIENT_ID=aestheticore-api
KEYCLOAK_CLIENT_SECRET=change_me

# JWT fallback (for Keycloak token validation)
JWT_SECRET=change_me_to_a_long_random_string

# AWS S3 (file storage)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
AWS_S3_BUCKET=aestheticore-dev

# Notifications
TWILIO_ACCOUNT_SID=change_me
TWILIO_AUTH_TOKEN=change_me
TWILIO_FROM_NUMBER=+1234567890

SENDGRID_API_KEY=change_me
SENDGRID_FROM_EMAIL=noreply@aestheticore.com

LINE_CHANNEL_ACCESS_TOKEN=change_me
LINE_CHANNEL_SECRET=change_me

# Payment (Omise)
OMISE_PUBLIC_KEY=change_me
OMISE_SECRET_KEY=change_me

# BullMQ / Queue
QUEUE_PREFIX=aestheticore

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4200

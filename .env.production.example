# =============================================================================
# AesthetiCore — Production Environment (DigitalOcean App Platform)
# These are set in the DO dashboard or .do/app.yaml, NOT in a file on disk.
# =============================================================================

NODE_ENV=production
PORT=8080

# Database — auto-injected by DO managed database (${db.DATABASE_URL})
DATABASE_URL=postgresql://user:password@host:25060/aestheticore?sslmode=require

# Auth
JWT_SECRET=<generate-a-64-char-random-string>

# CORS — auto-set via ${APP_URL}
CORS_ORIGINS=https://aestheticore-xxxxx.ondigitalocean.app

# Frontend — set as BUILD_TIME env for the static site
VITE_API_URL=https://aestheticore-xxxxx.ondigitalocean.app/api
